# ── Base de Datos PostgreSQL ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://netmon_user:CHANGE_ME@localhost:5432/network_monitor

# Conexión síncrona (usada por el motor ETL con psycopg2)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=network_monitor
PG_USER=netmon_user
PG_PASSWORD=CHANGE_ME

# ── Wazuh Indexer (OpenSearch) ──────────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=CHANGE_ME
